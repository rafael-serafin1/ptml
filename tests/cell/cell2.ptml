<!-- XML like definition -->
<?ptml encoding="UTF-8" terminal-resize="static"?>

<!-- Terminal Window Reference (not mandatory) -->
<terminal x-align="start">
    <snippet id="important">
        foreground="gold"
    </snippet>

    <!-- Simple Box with a Title -->
    <block title="PTML" border="rounded">
        <!-- Children are distributed in column pattern -->
        <column>
            <!-- Children are distributed in row pattern -->
            <row>
                <!-- Divide first concret parent by the number of cells -->
                <cell>
                    <box border-color="gray">
                        <!-- Prints out a text -->
                        <row>
                            <text snippet="important">Hello <frag font="italic">World</frag>!</text>
                        </row>
                    </box>
                </cell>
                <cell>
                    <box border-color="gray">
                        <row>
                            <text>GoodBye <frag font="italic">World</frag>!</text>
                        </row>
                    </box>
                </cell>
            </row>
            <row>
                <cell>
                    <box border-color="gray">
                        <row>
                            <text snippet="important">Hello <frag font="italic">World</frag>!</text>
                        </row>
                    </box>
                </cell>
                <!-- AINDA GERA UMA QUARTA CÉLULA, MESMO QUE VAZIA -->
                <!-- Isso não deveria acontecer, oque deveria acontecer é que a célula de baixo teria largura para cobrir toda a parte de baixo -->
                <!-- Enquanto que a parte de cima fica dividida pelas duas células -->
                <!-- TODO: Resolver essa bosta ai -->
            </row>
        </column>
    </block>
</terminal>
<!-- THIS IS A PTML TEST FILE -->