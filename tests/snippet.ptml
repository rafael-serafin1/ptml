<?ptml encoding="UTF-8" terminal-resize="reflow"?>
<terminal x-align="start">
    <snippet id="alert">
        background="red"
    </snippet>
    <snippet id="error" extends="alert">
        foreground="gray"
    </snippet>
    <snippet id="fatal" extends="error">
        font="bold"
    </snippet>

    
    <snippet id="new">
        font="dim"
    </snippet>

    <snippet id="2">
        font="strike-through"
        foreground="blue"
    </snippet>
    
    <column>
        <row>
            <text snippet="fatal">!ERRO!</text>
        </row>
        <row>
            <text snippet="new">
                Opa
            </text>
        </row>
    </column>
</terminal>