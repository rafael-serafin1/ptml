{
    "compilerOptions": {
        "target": "ES2020",
        "module": "nodenext",

        "lib": [
            "ES2020"
        ],

        "outDir": "out",

        "rootDir": "client",

        "strict": true,

        "moduleResolution": "nodenext",

        "esModuleInterop": true,

        "skipLibCheck": true,

        "sourceMap": true,

        "types": [
            "node",
            "vscode"
        ]
    },

    "include": [
        "client/**/*.ts"
    ],

    "exclude": [
        "node_modules"
    ]
}